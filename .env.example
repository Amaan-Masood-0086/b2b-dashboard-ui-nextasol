# Environment Variables — CloudPOS by NextaSol
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ---------------------------------------------------------------------------
# API Configuration
# The base URL of your CloudPOS backend REST API.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=https://api.yourbackend.com/v1

# ---------------------------------------------------------------------------
# App Identity
# ---------------------------------------------------------------------------
VITE_APP_NAME=CloudPOS
VITE_APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Demo / Development Mode
# When set to "true", the app uses mock data from src/lib/demo-data.ts
# and does NOT make real API calls. Ideal for UI development & demos.
# ---------------------------------------------------------------------------
VITE_DEMO_MODE=true

# ---------------------------------------------------------------------------
# Session Settings
# How many minutes of inactivity before the session timeout warning appears.
# ---------------------------------------------------------------------------
VITE_SESSION_TIMEOUT_MINUTES=30

# ---------------------------------------------------------------------------
# Feature Flags (optional)
# ---------------------------------------------------------------------------
# VITE_ENABLE_KITCHEN_DISPLAY=true
# VITE_ENABLE_SPLIT_PAYMENTS=true
# VITE_ENABLE_MEMBERSHIP_MODULE=true
